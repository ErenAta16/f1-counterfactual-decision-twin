# Copy this file to .env and fill in real values. .env is git-ignored;
# .env.example is committed so a reviewer knows which variables Phase 5
# needs without ever seeing a real credential (docs/PROJECT_PLAN.md,
# Section 8: "do not commit credentials; use environment variables").

# Cohere API key for the Phase 5 evidence/explanation layer
# (docs/EVIDENCE_INTERFACE.md). Used only to summarise validated
# calculations and cite retrieved regulation text; it never chooses a
# strategy or supplies a numerical input.
COHERE_API_KEY=
